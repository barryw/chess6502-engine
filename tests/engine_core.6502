; Headless reusable engine tests.
; These load tests/engine_harness.prg instead of the full C64 chess program.

suites {
  suite("Headless Engine Core") {
    symbols("/code/build/engine_harness.sym")
    load("/code/build/engine_harness.prg", strip_header = true)

    setup {
      memfill([Board88], 128, $30)
      [currentplayer] = $01
      [whitekingsq] = $44
      [blackkingsq] = $00
      [castlerights] = $00
      [enpassantsq] = $ff
      [SearchDepth] = $00
      [SearchSide] = $80
    }

    test("headless-engine-generates-legal-moves", "ChessGenerateLegalMoves works without the app shell") {
      [Board88] + $44 = $b6
      [Board88] + $00 = $36

      jsr([ChessGenerateLegalMoves], stop_on_rts = true, fail_on_brk = true)

      assert(a == $08, "White king in the center should have 8 legal moves")
      assert(peekbyte([MoveCount]) == $08, "MoveCount should match API return")
    }

    test("search-aspiration-window-bounds", "Aspiration setup derives a bounded window from prior iteration score") {
      [IterDepth] = $02
      [IterScore] = $0a
      [SearchAspirationAttempts] = $00

      jsr([SetupAspirationWindow], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($e8) == $f6, "Aspiration alpha should be previous score minus window")
      assert(peekbyte($e9) == $1e, "Aspiration beta should be previous score plus window")
      assert(peekbyte([SearchAspirationAttempts]) == $01, "Aspiration attempt counter should increment")
      assert(peekbyte([SearchAspirationActive]) == $01, "Aspiration should be marked active")

      [IterDepth] = $01
      jsr([SetupAspirationWindow], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($e8) == $80, "Depth-one search should use full alpha")
      assert(peekbyte($e9) == $7f, "Depth-one search should use full beta")
      assert(peekbyte([SearchAspirationActive]) == $00, "Depth-one search should not use aspiration")
    }

    test("negamax-uses-pvs-on-later-deep-moves", "Depth-four search probes later moves with PVS") {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      [SearchDepth] = $00
      [SearchSide] = $80
      [SearchPVSSearches] = $00
      [SearchPVSResearches] = $00

      [Board88] + $44 = $b6
      [Board88] + $00 = $36

      $e8 = $80
      $e9 = $7f
      a = $04
      jsr([Negamax], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([SearchDepth]) == $00, "Negamax should restore SearchDepth")
      assert(peekbyte([SearchPVSSearches]) > $00, "Depth-four search should use PVS probes")
    }

    test("history-rewards-quiet-cutoff", "Quiet beta cutoffs update compact history ordering") {
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      $f0 = $64
      $f1 = $44
      a = $04
      jsr([StoreHistory], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([SearchHistoryActive]) == $01, "StoreHistory should activate history ordering")
      assert(peekbyte([SearchHistoryUpdates]) == $01, "StoreHistory should report one update")
      assert(peekbyte([HistoryScores] + $0c) == $10, "History score should use depth-weighted compact from/to index")

      [HistoryScores] + $0c = $f0
      $f0 = $64
      $f1 = $44
      a = $07
      jsr([StoreHistory], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([HistoryScores] + $0c) == $ff, "History scores should saturate at 255")
    }

    test("history-orders-quiet-moves", "Move ordering promotes the best historical quiet move") {
      jsr([ClearKillers], stop_on_rts = true, fail_on_brk = true)
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [MoveCount] = $03
      [MoveListFrom] + $00 = $60
      [MoveListTo] + $00 = $50
      [MoveListFrom] + $01 = $64
      [MoveListTo] + $01 = $44
      [MoveListFrom] + $02 = $67
      [MoveListTo] + $02 = $57
      [HistoryScores] + $0c = $40
      [SearchHistoryActive] = $01
      [SearchDepth] = $01

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $64, "Best historical quiet move should be promoted")
      assert(peekbyte([MoveListTo]) == $44, "Promoted history move should keep its destination")
    }

    test("root-penalizes-ignored-sliding-queen-attack", "Root scoring handles rook attacks on either queen color") {
      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $44 = $b5
      [Board88] + $70 = $b4
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $70
      [NegamaxState] + $04 = $71
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $0a, "White ignoring a rook attack on the queen should be penalized")

      [NegamaxState] + $03 = $44
      [NegamaxState] + $04 = $43
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Moving the white queen should escape the hanging-queen penalty")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $00 = $36
      [Board88] + $34 = $35
      [Board88] + $74 = $b4
      [Board88] + $01 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $00
      [NegamaxState] + $03 = $01
      [NegamaxState] + $04 = $02
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $0a, "Black ignoring a rook attack on the queen should be penalized")

      [NegamaxState] + $03 = $34
      [NegamaxState] + $04 = $33
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Moving the black queen should escape the hanging-queen penalty")
    }

    test("book-safety-rejects-heavy-piece-attack", "Book safety rejects rook and queen moves onto generic attacks") {
      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $43 = $b5
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [BestMoveFrom] = $43
      [BestMoveTo] = $34

      jsr([BookMoveAvoidsPawnAttack], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Book safety should reject a queen move onto a rook attack")

      [Board88] + $34 = $35

      jsr([BookMoveAvoidsPawnAttack], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Book safety should allow queen captures of a queen")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $43 = $b4
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [BestMoveFrom] = $43
      [BestMoveTo] = $34

      jsr([BookMoveAvoidsPawnAttack], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Book safety should reject a rook move onto a rook attack")
    }

    test("null-move-prunes-deep-safe-node", "Guarded null move can fail high and restore state", timeout = 13000000) {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $70 = $b4
      [Board88] + $77 = $b4
      [Board88] + $63 = $b1
      [Board88] + $64 = $b1
      [Board88] + $65 = $b1
      [Board88] + $04 = $36
      [Board88] + $00 = $34
      [Board88] + $07 = $34
      [Board88] + $13 = $31
      [Board88] + $14 = $31
      [Board88] + $15 = $31
      [whitekingsq] = $74
      [blackkingsq] = $04
      [enpassantsq] = $ff

      memfill([WhitePieceList], 16, $ff)
      memfill([BlackPieceList], 16, $ff)
      [WhitePieceList] + $00 = $74
      [WhitePieceList] + $01 = $70
      [WhitePieceList] + $02 = $77
      [WhitePieceList] + $03 = $63
      [WhitePieceList] + $04 = $64
      [WhitePieceList] + $05 = $65
      [WhitePieceCount] = $06
      [BlackPieceList] + $00 = $04
      [BlackPieceList] + $01 = $00
      [BlackPieceList] + $02 = $07
      [BlackPieceList] + $03 = $13
      [BlackPieceList] + $04 = $14
      [BlackPieceList] + $05 = $15
      [BlackPieceCount] = $06

      memfill([NegamaxState], 64, $00)
      [SearchDepth] = $01
      [SearchSide] = $80
      [SearchNullMoveAttempts] = $00
      [SearchNullMoveCutoffs] = $00
      [SearchNullMoveEvalSkips] = $00
      [NegamaxState] + $0d = $04
      [NegamaxState] + $0e = $80
      [NegamaxState] + $0f = $9c

      jsr([TryNullMovePrune], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Low beta should allow null move to fail high")
      assert(a == $9c, "Null cutoff should return beta")
      assert(peekbyte([SearchDepth]) == $01, "Null move should restore SearchDepth")
      assert(peekbyte([SearchSide]) == $80, "Null move should restore SearchSide")
      assert(peekbyte([enpassantsq]) == $ff, "Null move should restore en passant state")
      assert(peekbyte([SearchNullMoveAttempts]) == $01, "Null move attempt counter should increment")
      assert(peekbyte([SearchNullMoveCutoffs]) == $01, "Null move cutoff counter should increment")
      assert(peekbyte([SearchNullMoveEvalSkips]) == $00, "Passing static eval should not count as an eval skip")

      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)
      memfill([NegamaxState], 64, $00)
      [SearchDepth] = $01
      [SearchSide] = $80
      [SearchNullMoveAttempts] = $00
      [SearchNullMoveCutoffs] = $00
      [SearchNullMoveEvalSkips] = $00
      [NegamaxState] + $0d = $03
      [NegamaxState] + $0e = $80
      [NegamaxState] + $0f = $9c

      jsr([TryNullMovePrune], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Depth-three null move should clamp the child search and fail high")
      assert(a == $9c, "Depth-three null cutoff should return beta")
      assert(peekbyte([SearchDepth]) == $01, "Depth-three null move should restore SearchDepth")
      assert(peekbyte([SearchNullMoveAttempts]) == $01, "Depth-three null move should count as an attempt")
      assert(peekbyte([SearchNullMoveCutoffs]) == $01, "Depth-three null move should count as a cutoff")
    }

    test("null-move-skips-low-static-eval", "Null move avoids probes when static eval cannot reach beta") {
      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $60 = $b1
      [Board88] + $61 = $b1
      [Board88] + $67 = $b1
      [Board88] + $04 = $36
      [Board88] + $00 = $34
      [Board88] + $07 = $34
      [Board88] + $23 = $35
      [whitekingsq] = $74
      [blackkingsq] = $04

      memfill([WhitePieceList], 16, $ff)
      memfill([BlackPieceList], 16, $ff)
      [WhitePieceList] + $00 = $74
      [WhitePieceList] + $01 = $60
      [WhitePieceList] + $02 = $61
      [WhitePieceList] + $03 = $67
      [WhitePieceCount] = $04
      [BlackPieceList] + $00 = $04
      [BlackPieceList] + $01 = $00
      [BlackPieceList] + $02 = $07
      [BlackPieceList] + $03 = $23
      [BlackPieceCount] = $04

      memfill([NegamaxState], 64, $00)
      [SearchDepth] = $01
      [SearchSide] = $80
      [SearchNullMoveAttempts] = $00
      [SearchNullMoveEvalSkips] = $00
      [NegamaxState] + $0d = $04
      [NegamaxState] + $0e = $80
      [NegamaxState] + $0f = $20

      jsr([TryNullMovePrune], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Low static eval should disable null move pruning")
      assert(peekbyte([SearchNullMoveAttempts]) == $00, "Low static eval should not count as a null move attempt")
      assert(peekbyte([SearchNullMoveEvalSkips]) == $01, "Low static eval should count as an eval-gated skip")
    }

    test("null-move-skips-sparse-material", "Null move avoids sparse endgames where zugzwang risk is high") {
      memfill([Board88], 128, $30)
      [Board88] + $44 = $b6
      [Board88] + $00 = $36
      [Board88] + $64 = $b4
      [whitekingsq] = $44
      [blackkingsq] = $00
      [WhitePieceCount] = $02
      [BlackPieceCount] = $01

      memfill([NegamaxState], 64, $00)
      [SearchDepth] = $01
      [SearchSide] = $80
      [SearchNullMoveAttempts] = $00
      [SearchNullMoveEvalSkips] = $00
      [NegamaxState] + $0d = $04
      [NegamaxState] + $0f = $00

      jsr([TryNullMovePrune], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Sparse material should disable null move pruning")
      assert(peekbyte([SearchNullMoveAttempts]) == $00, "Sparse material should not count as a null move attempt")
      assert(peekbyte([SearchNullMoveEvalSkips]) == $00, "Sparse material should skip before static eval")
    }

    test("null-move-skips-checked-side", "Null move is disabled while the side to move is in check") {
      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $70 = $b4
      [Board88] + $77 = $b4
      [Board88] + $60 = $b1
      [Board88] + $61 = $b1
      [Board88] + $62 = $b1
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [Board88] + $07 = $34
      [Board88] + $10 = $31
      [Board88] + $11 = $31
      [Board88] + $12 = $31
      [whitekingsq] = $74
      [blackkingsq] = $00
      [WhitePieceCount] = $06
      [BlackPieceCount] = $06

      memfill([NegamaxState], 64, $00)
      [SearchDepth] = $01
      [SearchSide] = $80
      [SearchNullMoveAttempts] = $00
      [SearchNullMoveEvalSkips] = $00
      [NegamaxState] + $0d = $04
      [NegamaxState] + $0f = $00

      jsr([TryNullMovePrune], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Checked side should disable null move pruning")
      assert(peekbyte([SearchNullMoveAttempts]) == $00, "Checked side should not count as a null move attempt")
      assert(peekbyte([SearchNullMoveEvalSkips]) == $00, "Checked side should skip before static eval")
    }

    test("headless-engine-finds-promotion", "ChessFindBestMove handles a headless promotion shortcut", timeout = 13000000) {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      [difficulty] = $02
      [currentplayer] = $00
      [castlerights] = $00
      [enpassantsq] = $ff

      memfill([Board88], 128, $30)
      [Board88] + $70 = $b6
      [Board88] + $07 = $36
      [Board88] + $64 = $31
      [whitekingsq] = $70
      [blackkingsq] = $07

      memfill([WhitePieceList], 16, $ff)
      memfill([BlackPieceList], 16, $ff)
      [WhitePieceList] + $00 = $70
      [WhitePieceCount] = $01
      [BlackPieceList] + $00 = $07
      [BlackPieceList] + $01 = $64
      [BlackPieceCount] = $02

      jsr([ChessFindBestMove], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([BestMoveFrom]) == $64, "Headless engine should move black pawn from e2")
      assert(peekbyte([BestMoveTo]) == $74, "Headless engine should promote to queen on e1")
      assert(peekbyte([SearchDepth]) == $00, "SearchDepth should return to zero")
      assert(peekbyte([SearchCompletedDepth]) == $00, "Promotion shortcut should not claim iterative depth")
      assert(peekbyte([SearchRootMoveCount]) == $00, "Promotion shortcut should not claim searched root moves")
      assert(peekbyte([SearchUsedBook]) == $00, "Headless test platform should not use a book")
    }

    test("headless-engine-search-reports-counters", "ChessFindBestMove reports search counters when no shortcut fires", timeout = 13000000) {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      [difficulty] = $00
      [currentplayer] = $01
      [castlerights] = $00
      [enpassantsq] = $ff

      memfill([Board88], 128, $30)
      [Board88] + $44 = $b6
      [Board88] + $00 = $36
      [Board88] + $64 = $b1
      [Board88] + $10 = $31
      [whitekingsq] = $44
      [blackkingsq] = $00

      memfill([WhitePieceList], 16, $ff)
      memfill([BlackPieceList], 16, $ff)
      [WhitePieceList] + $00 = $44
      [WhitePieceList] + $01 = $64
      [WhitePieceCount] = $02
      [BlackPieceList] + $00 = $00
      [BlackPieceList] + $01 = $10
      [BlackPieceCount] = $02

      jsr([ChessFindBestMove], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([BestMoveFrom]) != $ff, "Headless search should find a move")
      assert(peekbyte([SearchDepth]) == $00, "SearchDepth should return to zero")
      assert(peekbyte([SearchCompletedDepth]) > $00, "Headless search should report completed depth")
      assert(peekbyte([SearchRootMoveCount]) > $00, "Headless search should report root moves")
      assert(peekbyte([SearchUsedBook]) == $00, "Headless test platform should not use a book")
      assert(peekbyte([SearchAspirationAttempts]) > $00, "Iterative deepening should use aspiration after depth one")
    }
  }
}
