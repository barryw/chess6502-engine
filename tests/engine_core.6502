; Headless reusable engine tests.
; These load tests/engine_harness.prg instead of the full C64 chess program.

suites {
  suite("Headless Engine Core") {
    symbols("/code/build/engine_harness.sym")
    load("/code/build/engine_harness.prg", strip_header = true)

    setup {
      memfill([Board88], 128, $30)
      [currentplayer] = $01
      [whitekingsq] = $44
      [blackkingsq] = $00
      [castlerights] = $00
      [enpassantsq] = $ff
      [SearchDepth] = $00
      [SearchSide] = $80
    }

    test("headless-engine-generates-legal-moves", "ChessGenerateLegalMoves works without the app shell") {
      [Board88] + $44 = $b6
      [Board88] + $00 = $36

      jsr([ChessGenerateLegalMoves], stop_on_rts = true, fail_on_brk = true)

      assert(a == $08, "White king in the center should have 8 legal moves")
      assert(peekbyte([MoveCount]) == $08, "MoveCount should match API return")
    }

    test("search-aspiration-window-bounds", "Aspiration setup derives a bounded window from prior iteration score") {
      [IterDepth] = $02
      [IterScore] = $0a
      [SearchAspirationAttempts] = $00

      jsr([SetupAspirationWindow], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($e8) == $f6, "Aspiration alpha should be previous score minus window")
      assert(peekbyte($e9) == $1e, "Aspiration beta should be previous score plus window")
      assert(peekbyte([SearchAspirationAttempts]) == $01, "Aspiration attempt counter should increment")
      assert(peekbyte([SearchAspirationActive]) == $01, "Aspiration should be marked active")

      [IterDepth] = $01
      jsr([SetupAspirationWindow], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($e8) == $80, "Depth-one search should use full alpha")
      assert(peekbyte($e9) == $7f, "Depth-one search should use full beta")
      assert(peekbyte([SearchAspirationActive]) == $00, "Depth-one search should not use aspiration")
    }

    test("negamax-uses-pvs-on-later-deep-moves", "Depth-four search probes later moves with PVS") {
      jsr([InitZobristTables], stop_on_rts = true, fail_on_brk = true)
      jsr([TTClear], stop_on_rts = true, fail_on_brk = true)

      [SearchDepth] = $00
      [SearchSide] = $80
      [SearchPVSSearches] = $00
      [SearchPVSResearches] = $00

      [Board88] + $44 = $b6
      [Board88] + $00 = $36

      $e8 = $80
      $e9 = $7f
      a = $04
      jsr([Negamax], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([SearchDepth]) == $00, "Negamax should restore SearchDepth")
      assert(peekbyte([SearchPVSSearches]) > $00, "Depth-four search should use PVS probes")
    }

    test("history-rewards-quiet-cutoff", "Quiet beta cutoffs update compact history ordering") {
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      $f0 = $64
      $f1 = $44
      a = $04
      jsr([StoreHistory], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([SearchHistoryActive]) == $01, "StoreHistory should activate history ordering")
      assert(peekbyte([SearchHistoryUpdates]) == $01, "StoreHistory should report one update")
      assert(peekbyte([HistoryScores] + $0c) == $10, "History score should use depth-weighted compact from/to index")

      [HistoryScores] + $0c = $f0
      $f0 = $64
      $f1 = $44
      a = $07
      jsr([StoreHistory], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([HistoryScores] + $0c) == $ff, "History scores should saturate at 255")
    }

    test("history-orders-quiet-moves", "Move ordering promotes the best historical quiet move") {
      jsr([ClearKillers], stop_on_rts = true, fail_on_brk = true)
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [MoveCount] = $03
      [MoveListFrom] + $00 = $60
      [MoveListTo] + $00 = $50
      [MoveListFrom] + $01 = $64
      [MoveListTo] + $01 = $44
      [MoveListFrom] + $02 = $67
      [MoveListTo] + $02 = $57
      [HistoryScores] + $0c = $40
      [SearchHistoryActive] = $01
      [SearchDepth] = $01

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $64, "Best historical quiet move should be promoted")
      assert(peekbyte([MoveListTo]) == $44, "Promoted history move should keep its destination")
    }

    test("ordering-promotes-forcing-quiets", "Move ordering searches quiet checks and promotions before ordinary quiet moves") {
      jsr([ClearKillers], stop_on_rts = true, fail_on_brk = true)
      jsr([ClearHistory], stop_on_rts = true, fail_on_brk = true)

      memfill([Board88], 128, $30)
      [Board88] + $70 = $b6
      [Board88] + $77 = $b4
      [Board88] + $04 = $36
      [whitekingsq] = $70
      [blackkingsq] = $04
      [MoveCount] = $02
      [MoveListFrom] + $00 = $77
      [MoveListTo] + $00 = $67
      [MoveListFrom] + $01 = $77
      [MoveListTo] + $01 = $74

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $77, "Quiet checking rook move should be promoted")
      assert(peekbyte([MoveListTo]) == $74, "Quiet checking move should move to the front")

      memfill([Board88], 128, $30)
      [Board88] + $70 = $b6
      [Board88] + $77 = $b4
      [Board88] + $14 = $b1
      [Board88] + $00 = $36
      [whitekingsq] = $70
      [blackkingsq] = $00
      [MoveCount] = $02
      [MoveListFrom] + $00 = $77
      [MoveListTo] + $00 = $67
      [MoveListFrom] + $01 = $14
      [MoveListTo] + $01 = $04

      jsr([OrderMovesMVVLVA], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([MoveListFrom]) == $14, "Quiet promotion should be promoted before ordinary quiets")
      assert(peekbyte([MoveListTo]) == $04, "Quiet promotion destination should move to the front")
    }

    test("eval-rewards-bishop-pair", "Evaluation counts bishops and applies the bishop-pair bonus") {
      [EvalScore] = $00
      [EvalScore] + $01 = $00
      [EvalWhiteBishopCount] = $02
      [EvalBlackBishopCount] = $01

      jsr([ApplyBishopPairBonus], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $14, "White bishop pair should add the bishop-pair bonus")
      assert(peekbyte([EvalScore] + $01) == $00, "White bishop-pair bonus should keep score positive")

      [EvalScore] = $00
      [EvalScore] + $01 = $00
      [EvalWhiteBishopCount] = $01
      [EvalBlackBishopCount] = $02

      jsr([ApplyBishopPairBonus], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $ec, "Black bishop pair should subtract the bishop-pair bonus")
      assert(peekbyte([EvalScore] + $01) == $ff, "Black bishop-pair bonus should keep score negative")

      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $04 = $36
      [Board88] + $42 = $b3
      [Board88] + $45 = $b3
      [Board88] + $22 = $33
      [whitekingsq] = $74
      [blackkingsq] = $04

      jsr([EvaluatePosition], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalWhiteBishopCount]) == $02, "EvaluatePosition should count both white bishops")
      assert(peekbyte([EvalBlackBishopCount]) == $01, "EvaluatePosition should count the single black bishop")
    }

    test("eval-rewards-rooks-on-open-files", "Rook file activity scores open and semi-open files") {
      memfill([Board88], 128, $30)
      memfill([WhitePawnsPerFile], 8, $00)
      memfill([BlackPawnsPerFile], 8, $00)
      [Board88] + $70 = $b4
      [EvalScore] = $00
      [EvalScore] + $01 = $00

      jsr([EvaluateRookFileActivity], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $19, "White rook on an open file should get the full rook-file bonus")
      assert(peekbyte([EvalScore] + $01) == $00, "White open-file bonus should keep score positive")

      [EvalScore] = $00
      [EvalScore] + $01 = $00
      [BlackPawnsPerFile] = $01

      jsr([EvaluateRookFileActivity], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $0c, "White rook on a semi-open file should get the smaller bonus")

      [EvalScore] = $00
      [EvalScore] + $01 = $00
      [WhitePawnsPerFile] = $01

      jsr([EvaluateRookFileActivity], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $00, "Friendly pawns should block the white rook-file bonus")

      memfill([Board88], 128, $30)
      memfill([WhitePawnsPerFile], 8, $00)
      memfill([BlackPawnsPerFile], 8, $00)
      [Board88] + $07 = $34
      [EvalScore] = $00
      [EvalScore] + $01 = $00

      jsr([EvaluateRookFileActivity], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $e7, "Black rook on an open file should subtract the full rook-file bonus")
      assert(peekbyte([EvalScore] + $01) == $ff, "Black open-file bonus should keep score negative")

      [EvalScore] = $00
      [EvalScore] + $01 = $00
      [WhitePawnsPerFile] + $07 = $01

      jsr([EvaluateRookFileActivity], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $f4, "Black rook on a semi-open file should subtract the smaller bonus")
    }

    test("eval-rewards-knight-outposts", "Knight outposts require central support and no pawn chase") {
      memfill([Board88], 128, $30)
      [Board88] + $42 = $b1
      [EvalScore] = $00
      [EvalScore] + $01 = $00
      $f0 = $33
      $f1 = $80
      $f2 = $02

      jsr([EvaluateKnightOutpost], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $19, "Protected white knight outpost should get the outpost bonus")
      assert(peekbyte([EvalScore] + $01) == $00, "White outpost bonus should keep score positive")

      [Board88] + $24 = $31
      [EvalScore] = $00
      [EvalScore] + $01 = $00

      jsr([EvaluateKnightOutpost], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $00, "Enemy pawn attacks should cancel the white outpost bonus")

      memfill([Board88], 128, $30)
      [Board88] + $33 = $31
      [EvalScore] = $00
      [EvalScore] + $01 = $00
      $f0 = $44
      $f1 = $00
      $f2 = $02

      jsr([EvaluateKnightOutpost], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $e7, "Protected black knight outpost should subtract the outpost bonus")
      assert(peekbyte([EvalScore] + $01) == $ff, "Black outpost bonus should keep score negative")

      [EvalScore] = $00
      [EvalScore] + $01 = $00
      $f0 = $41
      $f1 = $00
      $f2 = $02

      jsr([EvaluateKnightOutpost], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $00, "Rim knights should not get the outpost bonus")
    }

    test("eval-penalizes-open-king-files", "King safety penalizes open and semi-open files around the king") {
      memfill([WhitePawnsPerFile], 8, $00)
      memfill([BlackPawnsPerFile], 8, $00)
      [EvalPawnCount] = $01
      [WhitePawnsPerFile] + $05 = $01
      [WhitePawnsPerFile] + $07 = $01
      $f1 = $00
      $f2 = $06

      jsr([ApplyWhiteKingFileExposure], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($f1) == $e7, "Open file beside a white king should subtract the full exposure penalty")

      memfill([WhitePawnsPerFile], 8, $00)
      memfill([BlackPawnsPerFile], 8, $00)
      [EvalPawnCount] = $01
      [WhitePawnsPerFile] + $05 = $01
      [WhitePawnsPerFile] + $07 = $01
      [BlackPawnsPerFile] + $06 = $01
      $f1 = $00
      $f2 = $06

      jsr([ApplyWhiteKingFileExposure], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($f1) == $f4, "Semi-open file beside a white king should subtract the smaller penalty")

      memfill([WhitePawnsPerFile], 8, $00)
      memfill([BlackPawnsPerFile], 8, $00)
      [EvalPawnCount] = $01
      [WhitePawnsPerFile] + $05 = $01
      [WhitePawnsPerFile] + $06 = $01
      [WhitePawnsPerFile] + $07 = $01
      $f1 = $00
      $f2 = $06

      jsr([ApplyWhiteKingFileExposure], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($f1) == $00, "Friendly pawns on nearby files should prevent white king exposure penalties")

      memfill([WhitePawnsPerFile], 8, $00)
      memfill([BlackPawnsPerFile], 8, $00)
      [EvalPawnCount] = $01
      [BlackPawnsPerFile] = $01
      [BlackPawnsPerFile] + $02 = $01
      $f1 = $00
      $f2 = $01

      jsr([ApplyBlackKingFileExposure], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($f1) == $e7, "Open file beside a black king should subtract the full exposure penalty")

      [EvalPawnCount] = $00
      $f1 = $00
      $f2 = $01

      jsr([ApplyBlackKingFileExposure], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($f1) == $00, "King exposure should skip when pawn counts are unavailable")
    }

    test("eval-penalizes-pinned-pieces", "King-ray pins make trapped defenders tactical targets") {
      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $64 = $b2
      [Board88] + $04 = $34
      [Board88] + $00 = $36
      [whitekingsq] = $74
      [blackkingsq] = $00
      [EvalScore] = $00
      [EvalScore] + $01 = $00

      jsr([EvaluateKingPins], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $e7, "White knight pinned to its king by a rook should be penalized")
      assert(peekbyte([EvalScore] + $01) == $ff, "White pin penalty should keep score negative")

      [Board88] + $53 = $31
      [EvalScore] = $00
      [EvalScore] + $01 = $00

      jsr([EvaluateKingPins], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $d3, "A white pinned knight attacked by a pawn should be punished harder")
      assert(peekbyte([EvalScore] + $01) == $ff, "Extra white pin pressure should keep score negative")

      memfill([Board88], 128, $30)
      [Board88] + $70 = $b6
      [Board88] + $74 = $b4
      [Board88] + $04 = $36
      [Board88] + $14 = $33
      [whitekingsq] = $70
      [blackkingsq] = $04
      [EvalScore] = $00
      [EvalScore] + $01 = $00

      jsr([EvaluateKingPins], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $19, "Black bishop pinned to its king by a rook should help white")
      assert(peekbyte([EvalScore] + $01) == $00, "Black pin penalty should keep score positive")

      [Board88] + $23 = $b1
      [EvalScore] = $00
      [EvalScore] + $01 = $00

      jsr([EvaluateKingPins], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $2d, "A black pinned bishop attacked by a pawn should be punished harder")
      assert(peekbyte([EvalScore] + $01) == $00, "Extra black pin pressure should keep score positive")

      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $64 = $b2
      [Board88] + $04 = $33
      [Board88] + $00 = $36
      [whitekingsq] = $74
      [blackkingsq] = $00
      [EvalScore] = $00
      [EvalScore] + $01 = $00

      jsr([EvaluateKingPins], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte([EvalScore]) == $00, "A bishop on the same file should not create an orthogonal pin")
      assert(peekbyte([EvalScore] + $01) == $00, "Non-pin score should stay neutral")
    }

    test("root-early-major-penalties-track-development", "Early queen and rook penalties require undeveloped home minors") {
      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $73 = $b5
      [Board88] + $00 = $36
      [whitekingsq] = $74
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $73
      [NegamaxState] + $04 = $64
      $eb = $50

      jsr([ApplyRootEarlyQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Developed positions should allow quiet queen moves")

      [Board88] + $71 = $b2
      $eb = $50

      jsr([ApplyRootEarlyQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $23, "Home minors should keep the early queen penalty active")

      memfill([Board88], 128, $30)
      [Board88] + $74 = $b6
      [Board88] + $70 = $b4
      [Board88] + $00 = $36
      [whitekingsq] = $74
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $70
      [NegamaxState] + $04 = $60
      $eb = $50

      jsr([ApplyRootEarlyRookPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Developed positions should allow quiet rook moves")

      [Board88] + $71 = $b2
      $eb = $50

      jsr([ApplyRootEarlyRookPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $0a, "Home minors should keep the early rook penalty active")
    }

    test("root-penalizes-ignored-sliding-queen-attack", "Root scoring handles rook attacks on either queen color") {
      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $44 = $b5
      [Board88] + $70 = $b4
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $70
      [NegamaxState] + $04 = $71
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $0a, "White ignoring a rook attack on the queen should be penalized")

      [NegamaxState] + $03 = $44
      [NegamaxState] + $04 = $43
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Moving the white queen should escape the hanging-queen penalty")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $44 = $b5
      [Board88] + $43 = $b3
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $43
      [NegamaxState] + $04 = $34
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Blocking a rook line to the queen should escape the hanging-queen penalty")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $44 = $b5
      [Board88] + $25 = $b2
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $25
      [NegamaxState] + $04 = $04
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Capturing the rook attacking the queen should escape the hanging-queen penalty")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $00 = $36
      [Board88] + $34 = $35
      [Board88] + $74 = $b4
      [Board88] + $01 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $00
      [NegamaxState] + $03 = $01
      [NegamaxState] + $04 = $02
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $0a, "Black ignoring a rook attack on the queen should be penalized")

      [NegamaxState] + $03 = $34
      [NegamaxState] + $04 = $33
      $eb = $50

      jsr([ApplyRootHangingQueenPenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Moving the black queen should escape the hanging-queen penalty")
    }

    test("book-safety-rejects-heavy-piece-attack", "Book safety rejects rook and queen moves onto generic attacks") {
      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $43 = $b5
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [BestMoveFrom] = $43
      [BestMoveTo] = $34

      jsr([BookMoveAvoidsPawnAttack], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Book safety should reject a queen move onto a rook attack")

      [Board88] + $34 = $35

      jsr([BookMoveAvoidsPawnAttack], stop_on_rts = true, fail_on_brk = true)

      assert(c == true, "Book safety should allow queen captures of a queen")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $43 = $b4
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [BestMoveFrom] = $43
      [BestMoveTo] = $34

      jsr([BookMoveAvoidsPawnAttack], stop_on_rts = true, fail_on_brk = true)

      assert(c == false, "Book safety should reject a rook move onto a rook attack")
    }

    test("root-penalizes-loose-piece-attack", "Root scoring protects undefended minors and rooks from non-pawn attacks") {
      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $44 = $b4
      [Board88] + $60 = $b1
      [Board88] + $00 = $36
      [Board88] + $17 = $33
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $60
      [NegamaxState] + $04 = $50
      $eb = $50

      jsr([ApplyRootLoosePiecePenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $0f, "Ignoring an undefended rook attacked by a bishop should be penalized")

      [NegamaxState] + $03 = $44
      [NegamaxState] + $04 = $45
      $eb = $50

      jsr([ApplyRootLoosePiecePenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Moving the attacked rook should avoid the loose-rook penalty")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $44 = $b4
      [Board88] + $25 = $b2
      [Board88] + $00 = $36
      [Board88] + $17 = $33
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $25
      [NegamaxState] + $04 = $17
      $eb = $50

      jsr([ApplyRootLoosePiecePenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Capturing the piece attacking the rook should avoid the loose-rook penalty")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $44 = $b4
      [Board88] + $62 = $b3
      [Board88] + $60 = $b1
      [Board88] + $00 = $36
      [Board88] + $17 = $33
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $60
      [NegamaxState] + $04 = $50
      $eb = $50

      jsr([ApplyRootLoosePiecePenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Defended rooks should not trigger the loose-rook penalty")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $44 = $b3
      [Board88] + $60 = $b1
      [Board88] + $00 = $36
      [Board88] + $04 = $34
      [whitekingsq] = $77
      [blackkingsq] = $00
      [SearchSide] = $80
      [NegamaxState] + $03 = $60
      [NegamaxState] + $04 = $50
      $eb = $50

      jsr([ApplyRootLoosePiecePenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $0f, "Ignoring an undefended bishop attacked by a rook should be penalized")

      [NegamaxState] + $03 = $44
      [NegamaxState] + $04 = $35
      $eb = $50

      jsr([ApplyRootLoosePiecePenalty], stop_on_rts = true, fail_on_brk = true)

      assert(peekbyte($eb) == $50, "Moving the attacked bishop should avoid the loose-piece penalty")

      memfill([Board88], 128, $30)
      [Board88] + $77 = $b6
      [Board88] + $74 = $b4
      [Board88] + $44 = $b3
